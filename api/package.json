{
  "name": "ipadecrypt-service-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "start": "bun src/server.ts",
    "dev": "bun --watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "build:web": "cd web && bun install --frozen-lockfile && bun run build",
    "typecheck:web": "cd web && bun install --frozen-lockfile && bun run typecheck"
  },
  "dependencies": {
    "express": "^4.21.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.2"
  }
}
